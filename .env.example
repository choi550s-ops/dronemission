# 서버 웹 루트에 .env 로 저장하세요 (FTP로 직접 업로드).
# 절대 GitHub 에 커밋하지 마세요 (.gitignore 에 포함됨).
APP_NAME=IUCCS
APP_ENV=production

DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password

# 최초 계정(admin, 팀) 비밀번호 — 최초 로그인 후 변경하세요.
INIT_PASSWORD=changeme1234

# migrate.php 웹 호출 보호용 토큰 — 길고 무작위로.
MIGRATE_TOKEN=change-this-to-a-long-random-string
