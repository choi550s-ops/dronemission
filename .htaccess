# --- IUCCS Apache configuration (works at web root or in a subfolder) ---

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Pass the Authorization header through to PHP (many hosts strip it).
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Block direct access to code/config/data directories.
    # Pattern is relative to this app folder, so it works under /dronemission/ too.
    RewriteRule ^(config|src|bin|db|\.github)(/|$) - [F,L]

    # Serve real files/dirs directly; route everything else to the front controller.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

# Block sensitive files by name (any location).
<FilesMatch "^\.env$|\.sql$|composer\.(json|lock)$|\.md$|\.gitignore$|\.ya?ml$">
    Require all denied
</FilesMatch>
